# Ignore per-phase context files
**/.context_*.md
data_layer/context.md
__pycache__/
*.pyc

# Generated data artifacts
data_layer/raw/
data_layer/reports/
model_layer/reports/

# Keep deployable UI JSON artifacts
!data_layer/reports/
!data_layer/reports/batches/
!data_layer/reports/batches/ui/
!data_layer/reports/batches/ui/**/*.json
!data_layer/reports/batches/ui/**/*.jsonl

# Keep yearly graph artifacts needed for local visualization
!model_layer/reports/
!model_layer/reports/graph_sih_br_2021.gexf
!model_layer/reports/graph_sih_br_2021_summary.json

# Temporary and lock files
*.part
*.tmp
*.swp
